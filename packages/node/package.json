{
  "name": "@waves-counter/node",
  "version": "0.2.2",
  "description": "Native Node and Express integration for Wave Counter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willylatorre/wave-counter.git",
    "directory": "packages/node"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    }
  },
  "files": [
    "dist",
    "*.node",
    "README.md"
  ],
  "scripts": {
    "build:native": "napi build --platform --release",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:native && npm run build:ts",
    "test": "npm run build && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.1.2",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.14",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
