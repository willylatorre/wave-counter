{
  "name": "@waves-counter/vue",
  "version": "0.1.2",
  "description": "Accessible Vue component and composable for Wave Counter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willylatorre/wave-counter.git",
    "directory": "packages/vue"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly",
    "pretest": "npm run build --workspace @waves-counter/client",
    "test": "vitest run",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@waves-counter/client": "0.1.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vitest": "^3.2.4",
    "vue": "^3.5.0",
    "vue-tsc": "^3.0.3"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
