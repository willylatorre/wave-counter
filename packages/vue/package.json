{
  "name": "@wave-counter/vue",
  "version": "0.1.0",
  "description": "Accessible Vue component and composable for Wave Counter",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly",
    "test": "vitest run",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "@wave-counter/client": "0.1.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.3"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
