{
  "name": "wave-counter-monorepo",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.8.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willylatorre/wave-counter.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "node tooling/check-versions.mjs && node tooling/check-conformance.mjs && node tooling/check-dtos.mjs && node tooling/check-packages.mjs",
    "test:tooling": "node --test tooling/checks.test.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "yaml": "^2.8.1"
  }
}
